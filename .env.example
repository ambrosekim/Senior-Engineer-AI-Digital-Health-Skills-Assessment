# Postgres
POSTGRES_USER=postgres
# Set a strong password for the Postgres database
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_HOST=relational_db
POSTGRES_PORT=5432

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=all-minilm
OLLAMA_CHAT_MODEL=llama3.2

# App / CORS
BACKEND_URL=http://backend:6100
EMBEDDING_DIM=384
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Generate a random secret, e.g. `chainlit create-secret`
CHAINLIT_AUTH_SECRET=
CHAINLIT_USERNAME=
# Set a password for the Chainlit basic-auth login
CHAINLIT_PASSWORD=

# Host Ports
BACKEND_HOST_PORT=6100
FRONTEND_HOST_PORT=3000
CHAINLIT_HOST_PORT=8000
POSTGRES_HOST_PORT=5433
OLLAMA_HOST_PORT=11434
